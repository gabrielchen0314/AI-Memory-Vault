# ============================================================
# AI Memory Vault — 環境設定範本
# 複製此檔案為 .env 並填入你自己的設定值
# cp .env.example .env
# ============================================================


# ── LLM 設定 ─────────────────────────────────────────────
# 選擇 LLM 提供者：gemini（預設）或 ollama（本地）
LLM_PROVIDER=gemini

# [Gemini] 到 https://aistudio.google.com/app/apikey 取得
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.0-flash-lite

# [Ollama] 本地部署時設定（LLM_PROVIDER=ollama）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2


# ── 向量搜尋設定 ──────────────────────────────────────────
# 通常不需要修改，保持預設即可
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
SEARCH_TOP_K=5
USE_HYBRID_SEARCH=true
HYBRID_BM25_WEIGHT=0.4
RECENCY_BIAS_ENABLED=true
RECENCY_DECAY_DAYS=90


# ── Core Memory 設定 ──────────────────────────────────────
CORE_MEMORY_ENABLED=true
CORE_MEMORY_PATH=_system/core-memory.md


# ── 對話設定 ──────────────────────────────────────────────
MAX_HISTORY_TURNS=10


# ── API 設定 ──────────────────────────────────────────────
# 對外服務時改為 0.0.0.0，本機測試保持 127.0.0.1
API_HOST=127.0.0.1
API_PORT=8000


# ── LINE Messaging API 設定 ───────────────────────────────
# 步驟：
# 1. 前往 https://developers.line.biz/ 建立 Messaging API Channel
# 2. 在 Channel settings 取得 Channel secret
# 3. 在 Messaging API 頁籤發行 Channel access token
# 4. 設定 Webhook URL 為 https://你的伺服器:PORT/webhook/line
# 5. 啟用 Webhook、關閉 Auto-reply messages
#
# 未填寫時 LINE Bot 功能自動停用，不影響 CLI / MCP 使用
LINE_CHANNEL_SECRET=your_line_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
